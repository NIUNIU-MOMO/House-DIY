# House-DIY Vault
HOUSE_DIY_VAULT_PATH=~/House-DIY-Vault

# oMLX (OpenAI-compatible)
HOUSE_DIY_OMLX_BASE_URL=http://127.0.0.1:8000/v1
HOUSE_DIY_OMLX_API_KEY=
HOUSE_DIY_OMLX_LLM_MODEL=house-llm
HOUSE_DIY_OMLX_VLM_MODEL=house-vlm
HOUSE_DIY_OMLX_EMBED_MODEL=house-embed

# ComfyUI
HOUSE_DIY_COMFYUI_BASE_URL=http://127.0.0.1:8188

# SQLite
HOUSE_DIY_DATABASE_URL=sqlite:///./house_diy.db

# Local storage
HOUSE_DIY_UPLOAD_DIR=./data/uploads
HOUSE_DIY_OUTPUT_DIR=./data/output
HOUSE_DIY_PROJECTS_DIR=./data/projects
