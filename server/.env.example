# House-DIY Vault
HOUSE_DIY_VAULT_PATH=~/House-DIY-Vault

# oMLX (OpenAI-compatible)
HOUSE_DIY_OMLX_BASE_URL=http://127.0.0.1:8000/v1
HOUSE_DIY_OMLX_API_KEY=
HOUSE_DIY_OMLX_LLM_MODEL=house-llm
HOUSE_DIY_OMLX_VLM_MODEL=house-vlm-pro
# 主 VLM 返回 5xx 时是否自动回退（默认 false，严格使用上方配置）
# HOUSE_DIY_OMLX_VLM_FALLBACK_ENABLED=true
# HOUSE_DIY_OMLX_VLM_MODEL_FALLBACK=house-vlm
# 可选：按图源 A/B 切换 VLM alias（留空则使用 HOUSE_DIY_OMLX_VLM_MODEL）
HOUSE_DIY_OMLX_VLM_MODEL_CAD=
HOUSE_DIY_OMLX_VLM_MODEL_MARKETING=
HOUSE_DIY_OMLX_EMBED_MODEL=house-embed

# 可选：房间/墙体 segmentation ONNX（M3，见 docs/07-appendix-seg-models.md）
HOUSE_DIY_SEG_ENABLED=false
HOUSE_DIY_SEG_HINT_ENABLED=true
HOUSE_DIY_SEG_MODEL_PATH=

# ComfyUI
HOUSE_DIY_COMFYUI_BASE_URL=http://127.0.0.1:8188
HOUSE_DIY_COMFYUI_RENDER_TIMEOUT=900

# SQLite
HOUSE_DIY_DATABASE_URL=sqlite:///./house_diy.db

# Local storage
HOUSE_DIY_UPLOAD_DIR=./data/uploads
HOUSE_DIY_OUTPUT_DIR=./data/output
HOUSE_DIY_PROJECTS_DIR=./data/projects
